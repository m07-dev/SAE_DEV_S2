<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<!--
    Menu principal style Mario : ciel bleu, sol vert, titre rouge brique avec
    ombre noire (effet rétro). Tout en inline, pas de CSS externe.
-->
<BorderPane prefHeight="760.0" prefWidth="1150.0"
            style="-fx-background-color: #5C94FC;"
            xmlns="http://javafx.com/javafx/8.0.40"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="universite_paris8.iut.mfofana.sae_dev_app_test.controleur.MenuControleur">

    <!-- ===== CENTRE : titre + boutons ===== -->
    <center>
        <VBox alignment="CENTER" spacing="25" style="-fx-padding: 40;">

            <!-- Titre style Mario : rouge brique avec ombre noire dure -->
            <Label text="TOWER DEFENSE" textFill="#E52521"
                   style="-fx-font-family: 'Arial Black'; -fx-font-size: 80; -fx-font-weight: bold;
                          -fx-effect: dropshadow(one-pass-box, black, 0, 1, 6, 6);" />

            <Label text="★ SUPER TOWER ★" textFill="#FFD700"
                   style="-fx-font-family: 'Arial Black'; -fx-font-size: 28; -fx-font-weight: bold;
                          -fx-effect: dropshadow(one-pass-box, black, 0, 1, 3, 3);" />

            <Region prefHeight="40" />

            <!-- Bouton JOUER : couleur "?" block jaune -->
            <Button text="JOUER" onAction="#clicJouer"
                    prefWidth="300" prefHeight="70"
                    style="-fx-background-color: #F2A21C;
                           -fx-border-color: black;
                           -fx-border-width: 4;
                           -fx-background-radius: 0;
                           -fx-border-radius: 0;
                           -fx-text-fill: white;
                           -fx-font-family: 'Arial Black';
                           -fx-font-size: 28;
                           -fx-font-weight: bold;
                           -fx-effect: dropshadow(one-pass-box, black, 0, 1, 2, 2);
                           -fx-cursor: hand;" />

            <!-- Bouton QUITTER : couleur brique brune -->
            <Button text="QUITTER" onAction="#clicQuitter"
                    prefWidth="300" prefHeight="70"
                    style="-fx-background-color: #C84C0C;
                           -fx-border-color: black;
                           -fx-border-width: 4;
                           -fx-background-radius: 0;
                           -fx-border-radius: 0;
                           -fx-text-fill: white;
                           -fx-font-family: 'Arial Black';
                           -fx-font-size: 28;
                           -fx-font-weight: bold;
                           -fx-effect: dropshadow(one-pass-box, black, 0, 1, 2, 2);
                           -fx-cursor: hand;" />

        </VBox>
    </center>

    <!-- ===== BAS : sol vert style Mario ===== -->
    <bottom>
        <Rectangle width="1150" height="80" fill="#00A800"
                   stroke="black" strokeWidth="4" />
    </bottom>

</BorderPane>
